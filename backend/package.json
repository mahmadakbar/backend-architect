{
  "name": "todo-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon -r tsconfig-paths/register src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node src/prisma/seeder/index.ts",
    "swagger": "npx ts-node -r tsconfig-paths/register ./src/configs/swagger.generator.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:staged": "jest --bail --findRelatedTests",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose --env-file .env up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f app",
    "docker:restart": "docker-compose restart app",
    "docker:clean": "docker-compose down -v",
    "docker:studio": "docker-compose --profile tools up prisma-studio",
    "docker:migrate": "docker-compose exec app bunx prisma migrate deploy --schema=./src/prisma/schema.prisma",
    "prepare": "cd .. && husky install backend/.husky"
  },
  "prisma": {
    "schema": "./src/prisma/schema.prisma",
    "seed": "ts-node src/prisma/seeder/index.ts"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "npm run test:staged"
    ]
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^6.9.0",
    "@prisma/instrumentation": "^7.8.0",
    "@types/uuid": "^11.0.0",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.77.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-joi-validation": "^6.1.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.10",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.9.0",
    "prisma-common-error-handle": "^2.2.1",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^14.0.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "chai": "^5.2.0",
    "dotenv": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "lint-staged": "^16.4.0",
    "mocha": "^11.5.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3"
  }
}
