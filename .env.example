# Application Configuration
NODE_ENV=development
BRANCH=development

# Database Configuration
DB_USER=testtodo
DB_PASSWORD=admin123
DB_NAME=todo_postgres
DB_PORT=5432
DATABASE_URL=postgresql://testtodo:admin123@localhost:5432/todo_postgres?schema=public

# Backend Server Configuration
BACKEND_PORT=3131
BACKEND_BASE_URL=http://localhost:3131
LOG_LEVEL=info

# Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3131/api
NEXT_PUBLIC_KEY_SECRET=your-key-secret-here

# JWT Configuration (Generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=your-jwt-access-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
JWT_ACCESS_EXPIRES=60m
JWT_REFRESH_EXPIRES=7d

# Encryption Key (Generate with: openssl rand -base64 24)
KEY_SECRET=your-encryption-key-here

# OpenTelemetry Configuration (for observability and tracing)
TELEMETRY_ENABLED=true
TELEMETRY_SERVICE_NAME=ecommerce-backend
TELEMETRY_SERVICE_VERSION=1.0.0
TELEMETRY_OTLP_ENDPOINT=http://localhost:4318

# ==========================================
# INSTRUCTIONS
# ==========================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Generate secure secrets using:
#    openssl rand -base64 32  # For JWT_ACCESS_SECRET
#    openssl rand -base64 32  # For JWT_REFRESH_SECRET
#    openssl rand -base64 24  # For KEY_SECRET
# 3. Update the secrets in your .env file
# 4. To enable OpenTelemetry tracing:
#    - Set TELEMETRY_ENABLED=true
#    - Start Jaeger: docker-compose --profile monitoring up -d jaeger
#    - Access Jaeger UI at http://localhost:16686
